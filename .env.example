# =============================================================================
# Floras — environment template
# Copy to `.env.local`:  cp .env.example .env.local
# `pnpm dev:convex` / `npx convex dev` will fill NEXT_PUBLIC_CONVEX_URL +
# CONVEX_DEPLOYMENT automatically.
# =============================================================================

# -----------------------------------------------------------------------------
# Next.js (.env.local)
# Generation, Box, publish, and Autumn run in Next.js API routes — not Convex.
# -----------------------------------------------------------------------------

# Public site URL for SEO (canonical, Open Graph, sitemap, robots)
# e.g. https://floras.ai
NEXT_PUBLIC_APP_URL=

# Convex client URL (required)
NEXT_PUBLIC_CONVEX_URL=

# Convex deployment name, e.g. "dev:happy-animal-123"
CONVEX_DEPLOYMENT=

# Autumn billing (app/api/autumn/[...all] + credit checks)
AUTUMN_SECRET_KEY=

# Anthropic (site generation / agent)
ANTHROPIC_API_KEY=

# Optional default model id (claude-sonnet-5 | claude-opus-4-8 | claude-fable-5)
# AGENT_MODEL=claude-sonnet-5

# box.ascii.dev sandboxes (preview + in-box build/deploy)
BOX_API_KEY=
# BOX_BASE_URL=https://ascii.dev/api/box/v1

# Cloudflare Pages (publish + custom domains)
# Token scope: Account → Cloudflare Pages → Edit
# Do NOT put these in Box Dashboard → Secrets (user Boxes are noEnv).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional: isolate cloud coding agents from your personal Convex deployment
# CONVEX_AGENT_MODE=anonymous

# -----------------------------------------------------------------------------
# Convex deployment env (set with: npx convex env set KEY value)
# Not read from .env.local by Convex functions.
# -----------------------------------------------------------------------------

# Autumn (Convex-side billing helpers, if used)
# AUTUMN_SECRET_KEY=

# Convex Auth — provision once with: npx @convex-dev/auth
# JWT_PRIVATE_KEY=
# JWKS=
# SITE_URL=http://localhost:3000

# Usually set automatically by Convex
# CONVEX_SITE_URL=

# Magic links via Resend
# AUTH_RESEND_KEY=
# AUTH_EMAIL_FROM=Floras <onboarding@resend.dev>
