# Cloudflare
CF_API_TOKEN=                   # “Pages : Edit” scope token
CLOUDFLARE_API_TOKEN=           # “Pages : Edit” scope token
CF_ACCOUNT_ID=                  # 32-char Account ID
CLOUDFLARE_ACCOUNT_ID=          # 32-char Account ID

# GitLab
GITLAB_TOKEN=                   # PAT with `api` scope
TEMPLATE_ID=69784252            # numeric project-ID of the starter repo
GROUP=bittive-group             # GitLab namespace that owns every site repo

