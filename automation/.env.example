# Cloudflare
CF_API_TOKEN=                         # “Pages : Edit” scope token
CLOUDFLARE_API_TOKEN=                 # Same as CF_API_TOKEN
CF_ACCOUNT_ID=                        # 32-char Account ID

# GitLab
GITLAB_TOKEN=                         # PAT with `api` scope
TEMPLATE_ID=123456                    # numeric project-ID of the starter repo
GROUP=company-group                   # GitLab namespace that owns every site repo

# Optional extras
RENOVATE_TOKEN=                       # only if you use Renovate
